# ============================================================================
# TriggerPoints AI Service — Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control
# ============================================================================

# --- REQUIRED ---

# Google Gemini API Key (free at https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your-gemini-api-key-here

# API authentication key for all endpoints
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEY=your-secure-api-key-here

# MongoDB Atlas connection string
# Get from: Atlas → your cluster → Connect → Drivers
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=triggerpoints

# --- OPTIONAL ---

GEMINI_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-004
CLASSIFIER_MODEL=gemini-2.0-flash
SESSION_MEMORY_LIMIT=6
