# ============================================================================
# TriggerPoints AI Service - Environment Configuration Template
# ============================================================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env file to version control - add to .gitignore
#
# For detailed instructions, see README.md
# ============================================================================

# ============================================================================
# REQUIRED CONFIGURATION
# ============================================================================

# Google Gemini API Key
# Get free at: https://aistudio.google.com/app/apikey
# Required for AI-powered responses
GEMINI_API_KEY=sk-your-gemini-api-key-here

# API Authentication Key
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Used to authenticate all API requests (except health check)
# Use strong, random values in production
API_KEY=your-secure-api-key-here

# ============================================================================
# OPTIONAL CONFIGURATION - Gemini AI Models
# ============================================================================

# Gemini model for chat responses
# Default: gemini-1.5-flash
# Options: gemini-1.5-flash (fast, cheaper), gemini-1.5-pro (better quality)
GEMINI_MODEL=gemini-1.5-flash

# Gemini model for embeddings/vector search
# Default: gemini-embedding-004
GEMINI_EMBEDDING_MODEL=gemini-embedding-004

# Model used for intelligent query classification
# Default: gemini-2.0-flash
# Routes queries to symptom/navigation/general handlers
CLASSIFIER_MODEL=gemini-2.0-flash

# ============================================================================
# OPTIONAL CONFIGURATION - Redis & Caching
# ============================================================================

# Redis connection URL
# Local development: redis://localhost:6379/0
# Docker setup: redis://redis:6379/0
# Remote/Production examples:
#   - Standard: redis://host:6379/0
#   - With password: redis://:password@host:6379/0
#   - Upstash (serverless): redis://:token@endpoint:6379
#   - AWS ElastiCache: redis://cluster-endpoint:6379
REDIS_URL=redis://localhost:6379/0

# Enable Redis (true/false)
# true = Uses Redis for caching and session memory
# false = Disables caching (NOT recommended for production)
USE_REDIS=true

# Cache Time-To-Live in seconds
# How long to store query responses
# Default: 86400 (24 hours)
# Common values:
#   3600 = 1 hour
#   86400 = 1 day (recommended)
#   604800 = 1 week
CACHE_TTL=86400

# ============================================================================
# OPTIONAL CONFIGURATION - Query Classification & Memory
# ============================================================================

# Enable ML-based query classification (true/false)
# true = Use Google Gemini for intelligent query routing
# false = Use keyword-based classification only
# Recommended: true for better accuracy
ENABLE_ML_CLASSIFIER=true

# Number of previous messages to maintain per session
# Default: 3
# Higher = more context but higher memory usage
# Typical range: 2-5
SESSION_MEMORY_LIMIT=3

# ============================================================================
# OPTIONAL CONFIGURATION - Logging & Monitoring
# ============================================================================

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
# Default: INFO
# Debug output: DEBUG
LOG_LEVEL=INFO

# Log format (simple, detailed, json)
# Default: simple
LOG_FORMAT=simple

# ============================================================================
# OPTIONAL CONFIGURATION - Server Deployment
# ============================================================================

# Server host binding
# 0.0.0.0 = Accept connections from any interface (production)
# 127.0.0.1 = Localhost only (development)
# Default: 0.0.0.0
SERVER_HOST=0.0.0.0

# Server port
# Default: 8000
SERVER_PORT=8000

# Rails/Gunicorn workers (for production)
# Default: 1 (development)
# Production: 2 * CPU_count + 1
# Examples: 2, 4, 8
UVICORN_WORKERS=1

# ============================================================================
# OPTIONAL CONFIGURATION - Data Paths
# ============================================================================

# Path to Excel symptoms database
# Default: app/data/raw/symptoms.xlsx
EXCEL_FILE_PATH=app/data/raw/symptoms.xlsx

# Path to FAISS vector index directory
# Default: app/data/faiss_index
FAISS_INDEX_PATH=app/data/faiss_index

# ============================================================================
# ENVIRONMENT-SPECIFIC SETTINGS
# ============================================================================

# Environment mode
# Options: development, production
# Affects logging level, error handling, CORS, etc.
ENVIRONMENT=development

# Enable CORS (Cross-Origin Resource Sharing)
# Default: true (development)
# Production: Configure specific origins only
ENABLE_CORS=true

# Allowed CORS origins (comma-separated for production)
# Examples:
#   Single: https://myapp.com
#   Multiple: https://myapp.com,https://www.myapp.com
# Default: http://localhost:3000,http://localhost:8000 (development)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ============================================================================
# DEPLOYMENT PLATFORM-SPECIFIC NOTES
# ============================================================================

# For Railway.app:
# - Use Dashboard to add PostgreSQL/Redis add-ons
# - Railway auto-detects Procfile or sets PORT env var
# - No configuration needed - auto-generated environment variables

# For Render.com:
# - Create Web Service from GitHub
# - Build: pip install -r requirements.txt
# - Start: uvicorn app.main:app --host 0.0.0.0 --port $PORT
# - Add Redis add-on or use Upstash (serverless Redis)

# For Google Cloud Run:
# - Deploy with: gcloud run deploy service-name --source .
# - Use Cloud Memorystore for managed Redis
# - Auto-sets PORT and GOOGLE_CLOUD_PROJECT env vars

# For AWS Lambda + API Gateway:
# - Package as layer or container image
# - Use AWS ElastiCache for Redis
# - Configure environment variables in Lambda dashboard

# For Local Docker:
# - Pass as: docker run -e GEMINI_API_KEY=xxx ...
# - Or use docker-compose with environment files

# ============================================================================

