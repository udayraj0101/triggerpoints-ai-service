# TriggerPoints AI Service - Environment Configuration
# Copy this file to .env and fill in your values

# === REQUIRED ===

# Google Gemini API Key (get from https://aistudio.google.com/app/apikeys)
GEMINI_API_KEY=your_gemini_api_key_here

# API Key for authentication (create your own random string)
# Used to protect the /chat endpoint via X-API-Key header
API_KEY=your_secret_api_key_here

# === OPTIONAL ===

# Gemini Model (default: gemini-2.5-flash)
# Options: gemini-1.5-flash, gemini-1.5-pro, gemini-2.5-flash, etc.
GEMINI_MODEL=gemini-2.5-flash

# Gemini Embedding Model (default: gemini-embedding-001)
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# === PHASE 2: SCALABILITY ===

# Redis Cache Configuration
# Set to "true" to enable Redis, "false" for in-memory cache
# If Redis unavailable, automatically falls back to in-memory
USE_REDIS=true

# Redis URL (default: local Redis on port 6379)
# For production: REDIS_URL=redis://:password@redis-host:6379/0
REDIS_URL=redis://localhost:6379/0

# Cache TTL in seconds (default: 86400 = 24 hours)
# Query responses cached for this duration
CACHE_TTL=86400

# ML-Based Query Classification
# Set to "true" to use Gemini for query classification (~90% accuracy)
# Set to "false" to use keyword matching (~70% accuracy)
ENABLE_ML_CLASSIFIER=true

# Classifier Model (default: gemini-2.0-flash, same as GEMINI_MODEL)
CLASSIFIER_MODEL=gemini-2.0-flash

API_KEY=your-api-key
